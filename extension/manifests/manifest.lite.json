{
  "manifest_version": 3,
  "name": "Ideation Lite",
  "version": "0.1.0",
  "description": "Quick voice-to-text: record, transcribe, copy. Powered by local Whisper AI.",
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "permissions": ["sidePanel", "tabs"],
  "host_permissions": [
    "https://huggingface.co/*",
    "https://*.huggingface.co/*",
    "https://*.hf.co/*",
    "https://*.xethub.hf.co/*",
    "https://cdn.jsdelivr.net/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Alt+I" },
      "description": "Open Ideation"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https://*.huggingface.co https://huggingface.co https://*.hf.co https://*.xethub.hf.co https://cdn.jsdelivr.net"
  }
}
