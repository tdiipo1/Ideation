{
  "name": "ideation-extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env VITE_EDITION=lite vite build --watch",
    "dev:full": "cross-env VITE_EDITION=full vite build --watch",
    "build:lite": "cross-env VITE_EDITION=lite vite build",
    "build:full": "cross-env VITE_EDITION=full vite build",
    "build": "npm run build:lite && npm run build:full"
  },
  "dependencies": {
    "@huggingface/transformers": "^3",
    "onnxruntime-web": "^1.21",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
